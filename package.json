{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bunx --bun vite",
        "build": "bunx --bun vite build",
        "build:ssr": "bunx --bun vite build && bunx --bun vite build --ssr",
        "1xxx": "",
        "fmt": "bunx prettier --check resources/ --cache",
        "fmt:ci": "bunx prettier --check resources/",
        "fmt:fix": "bunx prettier --write resources/ --cache --log-level warn",
        "lint": "bunx eslint . --cache",
        "lint:ci": "bunx eslint .",
        "lint:fix": "bunx eslint . --fix --cache",
        "2xxx": "",
        "types": "tsc --noEmit",
        "fix": "bun run fmt:fix && bun run lint:fix && bun run types",
        "prepare": "husky"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@laravel/vite-plugin-wayfinder": "^0.1.7",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@tsconfig/bun": "^1.0.10",
        "@types/bun": "^1.3.14",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.5",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "typescript-eslint": "^8.59.4"
    },
    "dependencies": {
        "@headlessui/react": "^2.2.10",
        "@inertiajs/react": "^3.1.1",
        "@inertiajs/vite": "^3.1.1",
        "@tailwindcss/vite": "^4.3.0",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.2.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "concurrently": "^9.2.1",
        "globals": "^15.15.0",
        "input-otp": "^1.4.2",
        "laravel-vite-plugin": "^3.1.0",
        "lucide-react": "^1.16.0",
        "radix-ui": "^1.4.3",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.9.3",
        "vite": "^8.0.13"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.9.5",
        "@rollup/rollup-win32-x64-msvc": "4.9.5",
        "@tailwindcss/oxide-linux-x64-gnu": "^4.3.0",
        "@tailwindcss/oxide-win32-x64-msvc": "^4.3.0",
        "lightningcss-linux-x64-gnu": "^1.32.0",
        "lightningcss-win32-x64-msvc": "^1.32.0"
    },
    "lint-staged": {
        "**/*": "bunx prettier --write --ignore-unknown --cache",
        "*.{ts,tsx}": [
            "bunx eslint --fix --cache",
            "bunx prettier --write --cache"
        ]
    },
    "packageManager": "bun@1.3.14"
}
